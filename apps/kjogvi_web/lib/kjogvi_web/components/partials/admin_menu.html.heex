  class="bg-zinc-800 border-t border-zinc-600 text-sm md:text-[0.8125rem] font-semibold py-1 px-1 md:px-2 text-center"
>
  <ul class="leading-7 md:leading-6">
    <li class="inline-block mx-2 text-[0.95rem] md:text-[0.85rem] text-zinc-500 uppercase tracking-wider">
      Admin
    </li>
    <.menu_bar_item>
      <.link href={~p"/admin/locations"} class="no-underline hover:underline">
        Common Locations
      </.link>
    </.menu_bar_item>
    <.menu_bar_item>
      <.link href={~p"/admin/ebird"} class="no-underline hover:underline">
